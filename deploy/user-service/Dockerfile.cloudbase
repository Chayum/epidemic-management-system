# 微信云托管 - User 服务
FROM maven:3.9-eclipse-temurin-17 AS builder
WORKDIR /app
COPY pom.xml .
COPY epidemic-common/pom.xml epidemic-common/
COPY epidemic-user-service/pom.xml epidemic-user-service/
RUN mvn dependency:go-offline -B
COPY epidemic-user-service/src epidemic-user-service/src
RUN mvn package -DskipTests -B

FROM eclipse-temurin:17-jre-alpine
COPY --from=builder /app/epidemic-user-service/target/*.jar /app.jar
EXPOSE 8081
ENTRYPOINT ["java", "-jar", "/app.jar"]
