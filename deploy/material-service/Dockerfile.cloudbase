# 微信云托管 - Material 服务
FROM maven:3.9-eclipse-temurin-17 AS builder
WORKDIR /app
COPY pom.xml .
COPY epidemic-common/pom.xml epidemic-common/
COPY epidemic-material-service/pom.xml epidemic-material-service/
RUN mvn dependency:go-offline -B
COPY epidemic-material-service/src epidemic-material-service/src
RUN mvn package -DskipTests -B

FROM eclipse-temurin:17-jre-alpine
COPY --from=builder /app/epidemic-material-service/target/*.jar /app.jar
EXPOSE 8082
ENTRYPOINT ["java", "-jar", "/app.jar"]
