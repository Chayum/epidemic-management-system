# 微信云托管 - Pandemic 服务
FROM maven:3.9-eclipse-temurin-17 AS builder
WORKDIR /app
COPY pom.xml .
COPY epidemic-common/pom.xml epidemic-common/
COPY epidemic-pandemic-service/pom.xml epidemic-pandemic-service/
RUN mvn dependency:go-offline -B
COPY epidemic-pandemic-service/src epidemic-pandemic-service/src
RUN mvn package -DskipTests -B

FROM eclipse-temurin:17-jre-alpine
COPY --from=builder /app/epidemic-pandemic-service/target/*.jar /app.jar
EXPOSE 8083
ENTRYPOINT ["java", "-jar", "/app.jar"]
